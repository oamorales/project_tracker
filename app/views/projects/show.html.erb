<div class="row">
  <div class="col-md-8">
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h2><%= @project.title %></h2>
        <span class="badge bg-<%= @project.active? ? 'success' : 'secondary' %>">
          <%= @project.status.humanize %>
        </span>
      </div>
      <div class="card-body">
        <p class="text-muted">Fecha límite: <%= @project.deadline.strftime("%d/%m/%Y") %></p>
        <p><%= @project.description %></p>

        <div class="progress mb-3">
          <div class="progress-bar" style="width: <%= @project.completion_percentage %>%">
            <%= @project.completion_percentage %>%
          </div>
        </div>
      </div>
    </div>

    <h3>Tareas del Proyecto</h3>
    <%= link_to "Nueva Tarea", new_task_path(project_id: @project.id), class: "btn btn-primary mb-3" %>

    <% if @project.tasks.any? %>
      <div class="list-group">
        <% @project.tasks.each do |task| %>
          <div class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-1"><%= task.title %></h5>
              <small class="text-<%= task.priority == 'high' ? 'danger' : 'muted' %>">
                Prioridad: <%= task.priority.humanize %>
              </small>
            </div>
            <span class="badge bg-<%= task.done? ? 'success' : 'warning' %> rounded-pill">
              <%= task.status.humanize %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted">No hay tareas asignadas a este proyecto.</p>
    <% end %>
  </div>
</div>

<div class="mt-4">
  <%= link_to "Editar", edit_project_path(@project), class: "btn btn-warning" %>
  <%= link_to "Volver", projects_path, class: "btn btn-secondary" %>
</div>
